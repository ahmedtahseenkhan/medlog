# Copy to .env and fill in values before running

# Shared
NODE_ENV=development

# Backend — also in apps/backend/.env.example
DATABASE_URL=postgresql://medlog:medlog@localhost:5435/medlog
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-in-production-min-32-chars
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=change-me-generate-with-openssl-rand-hex-32
PORT=3001

# Auth0 (Phase 1.2)
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# AWS (Phase 2.5 — radiology uploads)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=medlog-uploads-dev

# Claude API (Phase 3.3 — AI DDx + radiology fallback)
ANTHROPIC_API_KEY=

# AWS Transcribe Medical (Phase 3.2 — voice notes)
AWS_TRANSCRIBE_OUTPUT_BUCKET=medlog-transcripts-dev
# Uses same AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY above

# Radiology AI (Phase 3.5)
# 'claude' uses Claude Vision as fallback (no extra config needed)
# 'infermedica' requires the keys below
RADIOLOGY_AI_PROVIDER=claude
INFERMEDICA_API_KEY=
INFERMEDICA_APP_ID=

# VAPID keys for web push (Phase 2.3) — generate with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@medlog.app

# Hospital Information System (Phase 5.1.3)
HIS_FHIR_BASE_URL=
HIS_FHIR_API_KEY=

# App public URL — used in QR codes and invite links
APP_URL=http://localhost:5173
