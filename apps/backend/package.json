    "@aws-sdk/s3-request-presigner": "^3.726.1",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^9.0.3",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.1",
    "@medlog/types": "*",
    "@prisma/client": "^6.2.1",
    "@types/nodemailer": "^8.0.0",
    "bcrypt": "^5.1.1",
    "expo-server-sdk": "^3.14.0",
